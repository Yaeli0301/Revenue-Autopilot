{
  "name": "revenue-autopilot",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:worker": "pnpm --filter @revenue-autopilot/web worker:dev",
    "worker": "pnpm --filter @revenue-autopilot/web worker",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:generate": "turbo db:generate",
    "db:push": "turbo db:push",
    "db:studio": "pnpm --filter @revenue-autopilot/lib db:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=18"
  }
}
